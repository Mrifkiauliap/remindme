# ─── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Reminder Me Bro"
APP_VERSION="V.beta"
APP_URL=https://remindme.gentech.my.id
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
# Isi sesuai konfigurasi PostgreSQL kamu
# Docker Compose akan otomatis merakit DATABASE_URL dari variabel ini
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password_kuat_kamu
POSTGRES_DB=remindme

# ─── WhatsApp (WAHA) ─────────────────────────────────────────────────────────
ADMIN_NUMBERS=628xxxxxxxxxx
DEV_MODE=false

WAHA_URL=https://your-waha-instance.com/
WAHA_API_KEY=your-waha-api-key
WAHA_SESSION_NAME=default
WAHA_WEBHOOK_HMAC_KEY=your-hmac-key
WAHA_WEBHOOK_TOKEN=your-webhook-token
WAHA_COMMAND_PREFIX=.

# ─── Swagger UI ──────────────────────────────────────────────────────────────
SWAGGER_USER=admin
SWAGGER_PASS=change_me_to_strong_password
